#include<iostream>
using namespace std;

int main(){
    
    double celcius;
    double fahrenheit;
    cin >> celcius;
    fahrenheit = (celcius * 9.0 / 5.0) + 32.0;
    cout << fahrenheit << endl;
    
    return 0;
    
}


// GLOBAL VS LOCAL VARIABLE

#include<iostream>
using namespace std;
// global variable
int globalVaribale = 100;
int main(){
    // local variable
    int userInput;
    float result;
    
    cin >> userInput;
    result = (double)globalVaribale / userInput;
    
    cout << result << endl;
    return 0;
    
}




