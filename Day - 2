// Problem 2 -- If - else condition 
// to verify user's age wether eligible for vote or not ?
#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;
    // if condition 
    if(age >= 18) {
        // logic 
        cout << "Eligible For vote";
    } else {
        // logic 
        cout << "Not Eligible For vote";
    }
    return 0;
}



