// Problem 4 -- mirror of right angled triangle

#include <iostream>
using namespace std;
int main()
{
    int n;
   cin>>n;
   for(int i = 1; i <= n; i++)
   {
       for(int j = n-i;j >= 1;j--)
       {
           cout << " ";
       }
       for(int k = 1; k<=i;k++)
       {
       cout << "*";
       }
        cout << "\n";
   }
   
}


// Problem 5 
// Print a Rectangle

#include <iostream>
using namespace std;

int main() {
    int row, col;
    cin >> row;
    cin >> col;
    
    for(int i = 1; i <= row; i++) {
        for(int j = 1; j <= col; j++) {
            cout <<"*";
        }
        cout <<"\n";
    }
}


