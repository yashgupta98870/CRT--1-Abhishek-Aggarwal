// Problem 7
// Print a pyramid 

#include <iostream>
using namespace std;

int main() {
    for(int i = 1; i <= 6; i++) {
        for(int j = 6 - i; j >= 1; j--) {
            cout <<" ";
        }
        for(int k = 1; k <= i; k++) {
            cout << " *";
        }
        cout << "\n";
    }
}
