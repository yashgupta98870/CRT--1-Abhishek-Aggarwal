// Print a Solid square 

#include <iostream>
using namespace std;
int main()
{
    // number of times to print the pattern
    for(int i = 1; i <= 10; i++) {
        // this defines what to print in the pattern
        for(int j = 1; j <= 10; j++){
            cout << "* ";
        }
        cout << "\n";
    }

    return 0;
}



